<odoo>
    <record id="view_real_estate_project_tree" model="ir.ui.view">
        <field name="name">real.estate.project.tree</field>
        <field name="model">real.estate.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="land_id"/>
                <field name="estimated_budget"/>
                <field name="actual_cost"/>
                <field name="variance"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_real_estate_project_form" model="ir.ui.view">
        <field name="name">real.estate.project.form</field>
        <field name="model">real.estate.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_close" type="object" string="Close Project" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="land_id"/>
                        <field name="estimated_budget"/>
                        <field name="actual_cost" readonly="1"/>
                        <field name="variance" readonly="1"/>
                        <field name="completion_option"/>
                        <field name="analytic_account_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_real_estate_project" model="ir.actions.act_window">
        <field name="name">Projects WIP</field>
        <field name="res_model">real.estate.project</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_real_estate_project" name="Projects WIP" parent="real_estate_land.menu_real_estate_land_root" action="action_real_estate_project" sequence="20"/>
</odoo>
