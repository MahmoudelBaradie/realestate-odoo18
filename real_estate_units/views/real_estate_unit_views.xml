<odoo>
    <record id="view_real_estate_unit_tree" model="ir.ui.view">
        <field name="name">real.estate.unit.tree</field>
        <field name="model">real.estate.unit</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="unit_type"/>
                <field name="area"/>
                <field name="cost"/>
                <field name="target_price"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <record id="view_real_estate_unit_form" model="ir.ui.view">
        <field name="name">real.estate.unit.form</field>
        <field name="model">real.estate.unit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="unit_type"/>
                        <field name="area"/>
                        <field name="cost"/>
                        <field name="target_price"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_real_estate_unit" model="ir.actions.act_window">
        <field name="name">Units</field>
        <field name="res_model">real.estate.unit</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_real_estate_unit" name="Units" parent="real_estate_land.menu_real_estate_land_root" action="action_real_estate_unit" sequence="30"/>
</odoo>
